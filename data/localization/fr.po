# ==========data/scripts/player/background/simulation/scoutcommandnotetable.lua ==========
#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We saw a very large, very old gate in this sector."
msgstr "Nous avons vu une très grande et très vieille porte dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a big gate here."
msgstr "Il y a une grande porte ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A large, unusual, inactive gate is in this sector."
msgstr "Une grande porte inhabituelle et inactive se trouve dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Some strange, glowing asteroids in this sector. We stayed away."
msgstr "De curieux astéroïdes brillants dans ce secteur. Nous sommes restés à l'écart."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A very unusual ring of asteroids here. Are they charging something?"
msgstr "Un anneau d'astéroïdes très inhabituel ici. Chargent-ils quelque chose ?"

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "An unnatural arrangement of asteroids with a weird signal in this sector."
msgstr "Un arrangement artificiel d'astéroïdes avec un signal étrange dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Some very odd people are gathered around a big asteroid here."
msgstr "Des personnes très étranges sont rassemblées autour d'un gros astéroïde ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "People around an asteroid. Lots of chanting."
msgstr "Des gens autour d'un astéroïde. Beaucoup de chants."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "I think there are people worshipping a rock in this sector. Really."
msgstr "Je crois qu'il y a des gens qui vénèrent un rocher dans ce secteur. Vraiment."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "It looked empty at first, but there's a wormhole here."
msgstr "Cela semblait vide au début, mais il y a un trou de ver ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We almost stumbled straight into a wormhole in this sector."
msgstr "Nous sommes presque tombés directement dans un trou de ver dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Not sure where it goes, but there's a wormhole."
msgstr "Je ne sais pas où ça mène, mais il y a un trou de ver."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "An unusual satellite looping some research notes here."
msgstr "Un satellite inhabituel diffusant en boucle des notes de recherche ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A satellite in this sector talking about energy and stone."
msgstr "Un satellite dans ce secteur qui parle d'énergie et de pierre."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There's a satellite registered to 'M.A.D. Science' in this sector."
msgstr "Il y a un satellite enregistré au nom de 'M.A.D. Science' dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "I couldn't believe it, but there are still people surviving in this sector."
msgstr "Je n'arrivais pas à y croire, mais il y a encore des survivants dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Against all odds, there's a small outpost hiding from the Xsotan here."
msgstr "Contre toute attente, il y a un petit avant-poste qui se cache des Xsotans ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Some people claiming to be part of a resistance are stationed here."
msgstr "Des personnes se disant faire partie d'une résistance sont stationnées ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A very strange ring of asteroids here. Xsotan energy signatures."
msgstr "Un anneau d'astéroïdes très étrange ici. Signatures énergétiques Xsotan."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There's a circular formation of strange, numbered asteroids here."
msgstr "Il y a une formation circulaire d'étranges astéroïdes numérotés ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A ring of asteroids with inactive stations. Waiting for something."
msgstr "Un anneau d'astéroïdes avec des stations inactives. En attente de quelque chose."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "An abandoned ship is here that looks largely intact. It may be repairable."
msgstr "Un vaisseau abandonné est ici et semble en grande partie intact. Il pourrait être réparable."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A good repair crew might be able to get a ship we found flying again."
msgstr "Une bonne équipe de réparation pourrait faire voler à nouveau un vaisseau que nous avons trouvé."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A wreck in this sector is only lightly damaged. I bet we can repair it."
msgstr "Une épave dans ce secteur n'est que légèrement endommagée. Je parie que nous pouvons la réparer."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Also, some sort of communication beacon was active here."
msgstr "De plus, une sorte de balise de communication était active ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We also detected a signal from some sort of beacon."
msgstr "Nous avons également détecté un signal provenant d'une sorte de balise."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Oh, and there was a beacon broadcasting something about 'Exodus'."
msgstr "Oh, et il y avait une balise diffusant quelque chose à propos de 'L'Exode'."


# ==========data/scripts/player/background/simulation/simulation.lua ==========
#: data/scripts/player/background/simulation/simulation.lua:
msgid "Your captains continued working while you were away."
msgstr "Vos capitaines ont continué à travailler pendant votre absence."


# ==========data/scripts/player/background/simulation/simulationutility.lua ==========
#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "I'll have regular data for you as the mission progresses."
msgstr "J'aurai des données régulières pour vous au fur et à mesure de l'avancement de la mission."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "You'll receive frequent updates as we learn more."
msgstr "Vous recevrez des mises à jour fréquentes à mesure que nous en apprendrons davantage."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Expect a continual flow of new information."
msgstr "Attendez-vous à un flux continu de nouvelles informations."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "We have no deep scan ability and will have to visit every sector."
msgstr "Nous n'avons pas de capacité de scan profond et devrons visiter chaque secteur."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Travel time will be extreme without more deep scan coverage."
msgstr "Le temps de trajet sera extrême sans une plus grande couverture de scan profond."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "We can't see where hidden mass sectors are without better radar."
msgstr "Nous ne pouvons pas voir où se trouvent les secteurs de masse cachée sans un meilleur radar."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "With our weak sensors, we'll waste a lot of time jumping blindly."
msgstr "Avec nos capteurs faibles, nous allons perdre beaucoup de temps à sauter à l'aveuglette."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "We'd be a lot faster with more deep scan coverage."
msgstr "Nous serions beaucoup plus rapides avec une plus grande couverture de scan profond."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Hidden mass sectors will be hard to find without better radar."
msgstr "Les secteurs de masse cachée seront difficiles à trouver sans un meilleur radar."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "There's a refinery right here, so this will be fast and safe."
msgstr "Il y a une raffinerie juste ici, donc ce sera rapide et sûr."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Refining will be no problem with a depot right in this sector."
msgstr "Le raffinage ne posera aucun problème avec un dépôt juste dans ce secteur."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "I can autopilot right to the depot in this sector."
msgstr "Je peux utiliser le pilote automatique jusqu'au dépôt dans ce secteur."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "People are sure to appreciate our work here."
msgstr "Les gens apprécieront sûrement notre travail ici."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "This will help a lot of people."
msgstr "Cela aidera beaucoup de gens."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Our generosity will help to build trust."
msgstr "Notre générosité aidera à instaurer la confiance."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "This isn't my specialty, but I'll see what I can do."
msgstr "Ce n'est pas ma spécialité, mais je vais voir ce que je peux faire."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "A merchant would do this better, but I can give it a go."
msgstr "Un marchand ferait mieux, mais je peux essayer."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "No merchants available, commander?"
msgstr "Aucun marchand disponible, commandant ?"


