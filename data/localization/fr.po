# ========== data/scripts/player/background/simulation/scoutcommand.lua
# ==========
# ==========
# data/scripts/player/background/simulation/scoutcommandnotetable.lua
# ==========
#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors picked up a massive, dormant gate structure adrift in this sector."
msgstr ""
"Les capteurs ont détecté une structure de porte massive et dormante, à la "
"dérive dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We found a colossal ring gate here. It looks ancient and entirely dead."
msgstr ""
"Nous avons trouvé ici une porte circulaire colossale. Il a l'air ancien et "
"entièrement mort."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is an enormous, deactivated hyperspace gate floating silently in this "
"sector."
msgstr ""
"Il y a une énorme porte hyperspatiale désactivée qui flotte silencieusement "
"dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We mapped a monolithic ancient gate construct. Its original builders are "
"long gone."
msgstr ""
"Nous avons cartographié une construction de porte ancienne monolithique. Ses"
" constructeurs d'origine ont disparu depuis longtemps."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Asteroids in a perfect ring formation are emitting bizarre energy readings "
"here. We kept our distance."
msgstr ""
"Les astéroïdes en formation d’anneaux parfaite émettent ici des lectures "
"d’énergie bizarres. Nous avons gardé nos distances."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We detected a massive energy shield tethered to a cluster of glowing "
"asteroids."
msgstr ""
"Nous avons détecté un énorme bouclier énergétique attaché à un amas "
"d’astéroïdes brillants."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is a highly suspicious, shielded rock formation in this sector. "
"Proceed with caution."
msgstr ""
"Il existe une formation rocheuse protégée très suspecte dans ce secteur. "
"Procédez avec prudence."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"An unnatural arrangement of asteroids is broadcasting a hostile energy "
"signature in this area."
msgstr ""
"Un arrangement artificiel d'astéroïdes diffuse une signature énergétique "
"hostile dans cette zone."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors picked up a group of zealots obsessing over a massive asteroid."
msgstr ""
"Les capteurs ont détecté un groupe de fanatiques obsédés par un astéroïde "
"massif."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A strange cult seems to have set up camp around a giant rock in this sector."
msgstr ""
"Un étrange culte semble avoir installé son camp autour d'un rocher géant "
"dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We intercepted some unhinged radio chatter. Cultists are congregating around"
" an asteroid here."
msgstr ""
"Nous avons intercepté des discussions radio désordonnées. Les cultistes se "
"rassemblent ici autour d’un astéroïde."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There are fanatics out here worshipping an asteroid. Space madness is a "
"terrible thing."
msgstr ""
"Il y a des fanatiques ici qui adorent un astéroïde. La folie spatiale est "
"une chose terrible."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A localized spatial tear is present here. Looks like a stable wormhole."
msgstr ""
"Une déchirure spatiale localisée est ici présente. On dirait un trou de ver "
"stable."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners picked up a lone wormhole hidden in the void of this sector."
msgstr ""
"Les scanners ont détecté un trou de ver isolé caché dans le vide de ce "
"secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a wormhole phenomenon active here. Destination unknown."
msgstr "Il y a un phénomène de trou de ver actif ici. Destination inconnue."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We almost stumbled straight into a spatial anomaly. A wormhole is open in "
"this sector."
msgstr ""
"Nous avons failli tomber directement sur une anomalie spatiale. Un trou de "
"ver est ouvert dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We intercepted a repeating broadcast from a lone research satellite."
msgstr ""
"Nous avons intercepté une émission répétée d'un seul satellite de recherche."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"An automated science probe is transmitting strange data about asteroids "
"here."
msgstr ""
"Une sonde scientifique automatisée transmet ici d’étranges données sur les "
"astéroïdes."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A solitary satellite is pinging complex research telemetry in this sector."
msgstr ""
"Un satellite solitaire envoie une requête de télémétrie de recherche "
"complexe dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is an abandoned satellite registered to 'M.A.D. Science' looping its "
"logs here."
msgstr ""
"Il y a un satellite abandonné enregistré au nom de « M.A.D. La science "
"boucle ses journaux ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We stumbled upon a hidden resistance cell operating completely off the grid."
msgstr ""
"Nous sommes tombés sur une cellule de résistance cachée fonctionnant "
"complètement hors réseau."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Against all odds, there's a scrappy survivor outpost tucked away in this "
"sector."
msgstr ""
"Contre toute attente, il y a un avant-poste de survivants décousu caché dans"
" ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A heavily concealed resistance faction is holding out against the Xsotan "
"here."
msgstr ""
"Une faction de résistance fortement dissimulée résiste ici aux Xsotan."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We found a pocket of survivors out here claiming to be part of a rebellion."
msgstr ""
"Nous avons trouvé ici un groupe de survivants prétendant faire partie d'une "
"rébellion."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"An artificial ring of numbered asteroids and strange stations is adrift "
"here."
msgstr ""
"Un anneau artificiel d'astéroïdes numérotés et de stations étranges dérive "
"ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We found a complex arrangement of asteroids with strange numerical markings."
msgstr ""
"Nous avons trouvé un arrangement complexe d’astéroïdes avec d’étranges "
"marques numériques."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A dormant, circular array of asteroids and Xsotan tech is floating in this "
"sector."
msgstr ""
"Un réseau circulaire et endormi d'astéroïdes et de technologie Xsotan flotte"
" dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is a bizarre, ritualistic ring of marked asteroids generating faint "
"energy spikes."
msgstr ""
"Il y a un anneau rituel bizarre d’astéroïdes marqués générant de faibles "
"pics d’énergie."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors show a derelict ship with an intact core. We could restore it to "
"working order."
msgstr ""
"Les capteurs montrent un navire abandonné avec un noyau intact. Nous "
"pourrions le remettre en état de marche."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There's a heavily damaged but structurally sound ship abandoned in this "
"sector."
msgstr ""
"Il y a un navire lourdement endommagé mais structurellement sain, abandonné "
"dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We located an intact derelict vessel here. With a solid repair crew, she'll "
"fly again."
msgstr ""
"Nous avons localisé un navire abandonné intact ici. Avec une solide équipe "
"de réparation, elle volera à nouveau."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"I spotted a salvageable ship out here. It is practically begging to be "
"claimed and repaired."
msgstr ""
"J'ai repéré un vaisseau récupérable ici. Il ne demande pratiquement qu'à "
"être réclamé et réparé."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive debris fields and wrecked hulls detected in this sector."
msgstr ""
"Champs de débris massifs et coques naufragées détectées dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We mapped a graveyard of destroyed ships here. Prime salvaging territory."
msgstr ""
"Nous avons cartographié ici un cimetière de navires détruits. Territoire de "
"récupération privilégié."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is littered with the husks of dead ships."
msgstr "Ce secteur est jonché de carcasses de navires morts."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors show heavy wreckage concentrations in this area. Bring your salvage "
"lasers."
msgstr ""
"Les capteurs montrent de fortes concentrations d’épaves dans cette zone. "
"Apportez vos lasers de récupération."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A massive stash of lost cargo containers is floating freely here."
msgstr "Une énorme réserve de conteneurs perdus flotte librement ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We detected a dense cluster of abandoned shipping containers in this sector."
msgstr ""
"Nous avons détecté un groupe dense de conteneurs maritimes abandonnés dans "
"ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is a veritable goldmine of unbranded cargo crates adrift out here."
msgstr ""
"Il y a une véritable mine d’or de caisses sans marque à la dérive ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors picked up a large, unsecured container cache drifting in the void."
msgstr ""
"Les capteurs ont détecté un grand conteneur non sécurisé dérivant dans le "
"vide."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We picked up encrypted comms. Looks like a black market hub is nearby."
msgstr ""
"Nous avons récupéré des communications cryptées. On dirait qu'un centre de "
"marché noir se trouve à proximité."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A shady syndicate operates a hidden Smuggler's Market in this sector."
msgstr ""
"Un syndicat louche exploite un marché de contrebandiers caché dans ce "
"secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors detected a heavily cloaked Smuggler's Hideout operating off the "
"books."
msgstr ""
"Les capteurs ont détecté une cachette de contrebandier fortement masquée "
"opérant de manière clandestine."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a hive of scum and villainy tucked away in this area."
msgstr ""
"Il y a une ruche de racailles et de méchancetés cachées dans cette zone."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Dense asteroid clusters detected. Good prospects for a mining operation."
msgstr ""
"Amas denses d'astéroïdes détectés. Bonnes perspectives pour une opération "
"minière."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a massive, resource-rich asteroid field in this sector."
msgstr ""
"Nous avons cartographié un champ d'astéroïdes massif et riche en ressources "
"dans ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Heavy asteroid presence here. Prime territory for our mining lasers."
msgstr ""
"Forte présence d'astéroïdes ici. Territoire privilégié pour nos lasers "
"miniers."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners show a dense field of unmined rocks in this sector."
msgstr ""
"Les scanners montrent un champ dense de roches non exploitées dans ce "
"secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Hostile pirate signatures detected. They are heavily entrenched in this "
"sector."
msgstr ""
"Signatures de pirates hostiles détectées. Ils sont fortement implantés dans "
"ce secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A major pirate syndicate controls this area. Approach with weapons hot."
msgstr ""
"Un important syndicat de pirates contrôle cette zone. Approchez-vous avec "
"les armes chaudes."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors are lighting up with raider transponders. It's a pirate stronghold."
msgstr ""
"Les capteurs s'allument avec les transpondeurs raider. C'est un bastion des "
"pirates."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We spotted a large contingent of pirate scum operating in this sector."
msgstr ""
"Nous avons repéré un important contingent de pirates opérant dans ce "
"secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive alien energy spikes detected. The Xsotan are swarming here."
msgstr ""
"Des pics d'énergie extraterrestre massifs ont été détectés. Les Xsotan "
"pullulent ici."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We barely avoided a massive Xsotan breeding cluster in this sector."
msgstr ""
"Nous avons évité de peu un massif cluster d’élevage de Xsotan dans ce "
"secteur."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is heavily infested by the Xsotan menace."
msgstr "Ce secteur est fortement infesté par la menace Xsotan."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Alien bio-signatures confirmed. The Xsotan have claimed this space."
msgstr ""
"Bio-signatures extraterrestres confirmées. Les Xsotan ont revendiqué cet "
"espace."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We also picked up a repeating automated beacon on a forgotten frequency."
msgstr ""
"Nous avons également capté une balise automatique répétitive sur une "
"fréquence oubliée."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There's a strange navigational beacon here transmitting encrypted "
"coordinates."
msgstr ""
"Il y a une étrange balise de navigation ici transmettant des coordonnées "
"cryptées."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Also, a lone beacon is pulsing an 'Exodus' distress signal."
msgstr "De plus, une balise isolée émet un signal de détresse « Exodus »."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Oh, and I noted an ancient beacon broadcasting fragments of a mysterious "
"message."
msgstr ""
"Oh, et j'ai remarqué une ancienne balise diffusant des fragments d'un "
"message mystérieux."

# ========== data/scripts/player/background/simulation/simulation.lua
# ==========
#: data/scripts/player/background/simulation/simulation.lua:
msgid "Your captains continued working while you were away."
msgstr "Vos capitaines ont continué à travailler pendant votre absence."

# ========== data/scripts/player/background/simulation/simulationutility.lua
# ==========
#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "I'll have regular data for you as the mission progresses."
msgstr ""
"J'aurai des données régulières pour vous au fur et à mesure de l'avancement "
"de la mission."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "You'll receive frequent updates as we learn more."
msgstr ""
"Vous recevrez des mises à jour fréquentes à mesure que nous en apprendrons "
"davantage."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Expect a continual flow of new information."
msgstr "Attendez-vous à un flux continu de nouvelles informations."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(d93)We have no deep scan ability and will have to visit every "
"sector.\\c()"
msgstr ""
"\\c(d93)Nous n'avons pas de capacité d'analyse approfondie et devrons "
"visiter chaque secteur.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)Travel time will be extreme without more deep scan coverage.\\c()"
msgstr ""
"\\c(d93)Le temps de trajet sera extrême sans une couverture d'analyse plus "
"approfondie.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(d93)We can't see where hidden mass sectors are without better "
"radar.\\c()"
msgstr ""
"\\c(d93)Nous ne pouvons pas voir où se trouvent les secteurs de masse cachés"
" sans un meilleur radar.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(dd5)With our weak sensors, we'll waste a lot of time jumping "
"blindly.\\c()"
msgstr ""
"\\c(dd5)Avec nos capteurs faibles, nous perdrons beaucoup de temps à sauter "
"à l'aveugle.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)We'd be a lot faster with more deep scan coverage.\\c()"
msgstr ""
"\\c(dd5)Nous serions beaucoup plus rapides avec une couverture d'analyse "
"plus approfondie.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(dd5)Hidden mass sectors will be hard to find without better radar.\\c()"
msgstr ""
"\\c(dd5)Les secteurs de masse cachés seront difficiles à trouver sans un "
"meilleur radar.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)There's a refinery right here, so this will be fast and safe.\\c()"
msgstr "\\c(0d0)Il y a une raffinerie juste ici, donc ce sera rapide et sûr.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(0d0)Refining will be no problem with a depot right in this sector.\\c()"
msgstr ""
"\\c(0d0)Le raffinage ne posera aucun problème avec un dépôt directement dans"
" ce secteur.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)I can autopilot right to the depot in this sector.\\c()"
msgstr ""
"\\c(0d0)Je peux piloter automatiquement jusqu'au dépôt dans ce secteur.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)People are sure to appreciate our work here.\\c()"
msgstr "\\c(0d0)Les gens apprécieront certainement notre travail ici.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)This will help a lot of people.\\c()"
msgstr "\\c(0d0)Cela aidera beaucoup de gens.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)Our generosity will help to build trust.\\c()"
msgstr "\\c(0d0)Notre générosité contribuera à établir la confiance.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)This isn't my specialty, but I'll see what I can do.\\c()"
msgstr ""
"\\c(dd5)Ce n'est pas ma spécialité, mais je vais voir ce que je peux "
"faire.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)A merchant would do this better, but I can give it a go.\\c()"
msgstr "\\c(dd5)Un commerçant ferait mieux, mais je peux essayer.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)No merchants available, commander?\\c()"
msgstr "\\c(dd5)Aucun marchand disponible, commandant ?\\c()"

