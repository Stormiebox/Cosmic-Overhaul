#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners picked up a lone wormhole hidden in the void of this sector."
msgstr ""
"Os scanners detectaram um buraco de minhoca solitário escondido no vazio "
"deste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a wormhole phenomenon active here. Destination unknown."
msgstr "Há um fenômeno de buraco de minhoca ativo aqui. Destino desconhecido."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We intercepted a repeating broadcast from a lone research satellite."
msgstr ""
"Interceptamos uma transmissão repetida de um único satélite de pesquisa."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive debris fields and wrecked hulls detected in this sector."
msgstr ""
"Enormes campos de detritos e cascos destruídos detectados neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is littered with the husks of dead ships."
msgstr "Este setor está repleto de carcaças de navios mortos."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A massive stash of lost cargo containers is floating freely here."
msgstr ""
"Um enorme estoque de contêineres de carga perdidos flutua livremente aqui."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We picked up encrypted comms. Looks like a black market hub is nearby."
msgstr ""
"Captámos comunicações encriptadas. Parece que um centro do mercado negro "
"está próximo."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A shady syndicate operates a hidden Smuggler's Market in this sector."
msgstr ""
"Um sindicato obscuro opera um mercado de contrabandistas oculto neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a hive of scum and villainy tucked away in this area."
msgstr "Há uma colmeia de escória e vilania escondida nesta área."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a massive, resource-rich asteroid field in this sector."
msgstr ""
"Mapeamos um campo de asteróides enorme e rico em recursos neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Heavy asteroid presence here. Prime territory for our mining lasers."
msgstr ""
"Presença pesada de asteróides aqui. Território privilegiado para nossos "
"lasers de mineração."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners show a dense field of unmined rocks in this sector."
msgstr "Os scanners mostram um denso campo de rochas não minadas neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We spotted a large contingent of pirate scum operating in this sector."
msgstr "Vimos um grande contingente de piratas operando neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive alien energy spikes detected. The Xsotan are swarming here."
msgstr ""
"Enormes picos de energia alienígena detectados. Os Xsotan estão fervilhando "
"aqui."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We barely avoided a massive Xsotan breeding cluster in this sector."
msgstr ""
"Por pouco não conseguimos evitar um enorme aglomerado de criação de Xsotan "
"neste sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is heavily infested by the Xsotan menace."
msgstr "Este sector está fortemente infestado pela ameaça Xsotan."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Alien bio-signatures confirmed. The Xsotan have claimed this space."
msgstr ""
"Assinaturas biológicas alienígenas confirmadas. Os Xsotan reivindicaram este"
" espaço."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Also, a lone beacon is pulsing an 'Exodus' distress signal."
msgstr ""
"Além disso, um farol solitário está pulsando um sinal de socorro 'Êxodo'."

# ========== data/scripts/player/background/simulation/simulation.lua
# ==========
#: data/scripts/player/background/simulation/simulation.lua:
msgid "Your captains continued working while you were away."
msgstr "Seus capitães continuaram trabalhando enquanto você estava fora."

# ========== data/scripts/player/background/simulation/simulationutility.lua
# ==========
#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "I'll have regular data for you as the mission progresses."
msgstr "Terei dados regulares para você à medida que a missão avança."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "You'll receive frequent updates as we learn more."
msgstr "Você receberá atualizações frequentes à medida que aprendermos mais."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Expect a continual flow of new information."
msgstr "Espere um fluxo contínuo de novas informações."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)Travel time will be extreme without more deep scan coverage.\\c()"
msgstr ""
"\\c(d93)O tempo de viagem será extremo sem uma cobertura de varredura mais "
"profunda.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)We'd be a lot faster with more deep scan coverage.\\c()"
msgstr ""
"\\c(dd5)Seríamos muito mais rápidos com uma cobertura de varredura mais "
"profunda.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)There's a refinery right here, so this will be fast and safe.\\c()"
msgstr "\\c(0d0)Há uma refinaria bem aqui, então isso será rápido e seguro.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)I can autopilot right to the depot in this sector.\\c()"
msgstr ""
"\\c(0d0)Posso pilotar automaticamente direto para o depósito neste "
"setor.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)People are sure to appreciate our work here.\\c()"
msgstr "\\c(0d0)As pessoas certamente apreciarão nosso trabalho aqui.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)This will help a lot of people.\\c()"
msgstr "\\c(0d0)Isso ajudará muitas pessoas.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)Our generosity will help to build trust.\\c()"
msgstr "\\c(0d0)Nossa generosidade ajudará a construir confiança.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)This isn't my specialty, but I'll see what I can do.\\c()"
msgstr ""
"\\c(dd5)Essa não é minha especialidade, mas vou ver o que posso fazer.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)A merchant would do this better, but I can give it a go.\\c()"
msgstr "\\c(dd5)Um comerciante faria isso melhor, mas posso tentar.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)No merchants available, commander?\\c()"
msgstr "\\c(dd5)Nenhum comerciante disponível, comandante?\\c()"

