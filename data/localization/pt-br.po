# data/scripts/player/background/simulation/scoutcommandnotetable.lua
# ==========
#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors picked up a massive, dormant gate structure adrift in this sector."
msgstr ""
"Os sensores detectaram uma enorme estrutura de portão adormecida à deriva "
"neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We found a colossal ring gate here. It looks ancient and entirely dead."
msgstr ""
"Encontramos um portão circular colossal aqui. Parece antigo e totalmente "
"morto."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is an enormous, deactivated hyperspace gate floating silently in this "
"sector."
msgstr ""
"Há um enorme portão hiperespacial desativado flutuando silenciosamente neste"
" setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We mapped a monolithic ancient gate construct. Its original builders are "
"long gone."
msgstr ""
"Mapeamos uma construção de portão antigo monolítico. Seus construtores "
"originais já se foram."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Asteroids in a perfect ring formation are emitting bizarre energy readings "
"here. We kept our distance."
msgstr ""
"Asteróides em uma formação de anel perfeita estão emitindo leituras de "
"energia bizarras aqui. Mantivemos distância."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We detected a massive energy shield tethered to a cluster of glowing "
"asteroids."
msgstr ""
"Detectámos um enorme escudo de energia preso a um aglomerado de asteróides "
"brilhantes."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is a highly suspicious, shielded rock formation in this sector. "
"Proceed with caution."
msgstr ""
"Há uma formação rochosa altamente suspeita e protegida neste setor. Proceda "
"com cautela."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"An unnatural arrangement of asteroids is broadcasting a hostile energy "
"signature in this area."
msgstr ""
"Um arranjo não natural de asteroides está transmitindo uma assinatura de "
"energia hostil nesta área."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors picked up a group of zealots obsessing over a massive asteroid."
msgstr ""
"Sensores detectaram um grupo de fanáticos obcecados por um enorme asteroide."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A strange cult seems to have set up camp around a giant rock in this sector."
msgstr ""
"Um estranho culto parece ter montado acampamento em torno de uma rocha "
"gigante neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We intercepted some unhinged radio chatter. Cultists are congregating around"
" an asteroid here."
msgstr ""
"Interceptamos algumas conversas descontroladas no rádio. Os cultistas estão "
"se reunindo em torno de um asteroide aqui."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There are fanatics out here worshipping an asteroid. Space madness is a "
"terrible thing."
msgstr ""
"Há fanáticos por aqui adorando um asteroide. A loucura espacial é uma coisa "
"terrível."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A localized spatial tear is present here. Looks like a stable wormhole."
msgstr ""
"Um rasgo espacial localizado está presente aqui. Parece um buraco de minhoca"
" estável."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners picked up a lone wormhole hidden in the void of this sector."
msgstr ""
"Os scanners detectaram um buraco de minhoca solitário escondido no vazio "
"deste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a wormhole phenomenon active here. Destination unknown."
msgstr "Há um fenômeno de buraco de minhoca ativo aqui. Destino desconhecido."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We almost stumbled straight into a spatial anomaly. A wormhole is open in "
"this sector."
msgstr ""
"Quase tropeçamos direto em uma anomalia espacial. Um buraco de minhoca está "
"aberto neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We intercepted a repeating broadcast from a lone research satellite."
msgstr ""
"Interceptamos uma transmissão repetida de um único satélite de pesquisa."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"An automated science probe is transmitting strange data about asteroids "
"here."
msgstr ""
"Uma sonda científica automatizada está transmitindo dados estranhos sobre "
"asteróides aqui."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A solitary satellite is pinging complex research telemetry in this sector."
msgstr ""
"Um satélite solitário está efetuando pings de telemetria de investigação "
"complexa neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is an abandoned satellite registered to 'M.A.D. Science' looping its "
"logs here."
msgstr ""
"Existe um satélite abandonado registrado em nome de 'M.A.D. A ciência está "
"fazendo um loop aqui."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We stumbled upon a hidden resistance cell operating completely off the grid."
msgstr ""
"Deparamo-nos com uma célula de resistência oculta operando completamente "
"fora da rede."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Against all odds, there's a scrappy survivor outpost tucked away in this "
"sector."
msgstr ""
"Contra todas as probabilidades, há um posto avançado de sobreviventes "
"escondido neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A heavily concealed resistance faction is holding out against the Xsotan "
"here."
msgstr ""
"Uma facção de resistência fortemente ocultada está resistindo aos Xsotan "
"aqui."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We found a pocket of survivors out here claiming to be part of a rebellion."
msgstr ""
"Encontrámos aqui um grupo de sobreviventes que afirmam fazer parte de uma "
"rebelião."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"An artificial ring of numbered asteroids and strange stations is adrift "
"here."
msgstr ""
"Um anel artificial de asteróides numerados e estações estranhas está à "
"deriva aqui."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We found a complex arrangement of asteroids with strange numerical markings."
msgstr ""
"Encontramos um arranjo complexo de asteroides com estranhas marcações "
"numéricas."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A dormant, circular array of asteroids and Xsotan tech is floating in this "
"sector."
msgstr ""
"Um conjunto circular e adormecido de asteróides e tecnologia Xsotan está "
"flutuando neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is a bizarre, ritualistic ring of marked asteroids generating faint "
"energy spikes."
msgstr ""
"Há um anel bizarro e ritualístico de asteroides marcados gerando fracos "
"picos de energia."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors show a derelict ship with an intact core. We could restore it to "
"working order."
msgstr ""
"Sensores mostram uma nave abandonada com núcleo intacto. Poderíamos "
"restaurá-lo para funcionar."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There's a heavily damaged but structurally sound ship abandoned in this "
"sector."
msgstr ""
"Há um navio fortemente danificado, mas estruturalmente sólido, abandonado "
"neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We located an intact derelict vessel here. With a solid repair crew, she'll "
"fly again."
msgstr ""
"Localizamos aqui uma embarcação abandonada intacta. Com uma equipe de "
"reparos sólida, ela voará novamente."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"I spotted a salvageable ship out here. It is practically begging to be "
"claimed and repaired."
msgstr ""
"Avistei um navio recuperável aqui. Está praticamente implorando para ser "
"reclamado e reparado."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive debris fields and wrecked hulls detected in this sector."
msgstr ""
"Enormes campos de detritos e cascos destruídos detectados neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We mapped a graveyard of destroyed ships here. Prime salvaging territory."
msgstr ""
"Mapeámos aqui um cemitério de navios destruídos. Território de salvamento "
"principal."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is littered with the husks of dead ships."
msgstr "Este setor está repleto de carcaças de navios mortos."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors show heavy wreckage concentrations in this area. Bring your salvage "
"lasers."
msgstr ""
"Sensores mostram grandes concentrações de destroços nesta área. Traga seus "
"lasers de resgate."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A massive stash of lost cargo containers is floating freely here."
msgstr ""
"Um enorme estoque de contêineres de carga perdidos flutua livremente aqui."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We detected a dense cluster of abandoned shipping containers in this sector."
msgstr ""
"Detectamos um denso aglomerado de contêineres abandonados neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is a veritable goldmine of unbranded cargo crates adrift out here."
msgstr ""
"Há uma verdadeira mina de ouro de caixas de carga sem marca à deriva por "
"aqui."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors picked up a large, unsecured container cache drifting in the void."
msgstr ""
"Os sensores detectaram um grande cache de contêiner inseguro flutuando no "
"vazio."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We picked up encrypted comms. Looks like a black market hub is nearby."
msgstr ""
"Captámos comunicações encriptadas. Parece que um centro do mercado negro "
"está próximo."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A shady syndicate operates a hidden Smuggler's Market in this sector."
msgstr ""
"Um sindicato obscuro opera um mercado de contrabandistas oculto neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors detected a heavily cloaked Smuggler's Hideout operating off the "
"books."
msgstr ""
"Sensores detectaram um esconderijo de contrabandista fortemente camuflado "
"operando fora dos livros."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a hive of scum and villainy tucked away in this area."
msgstr "Há uma colmeia de escória e vilania escondida nesta área."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Dense asteroid clusters detected. Good prospects for a mining operation."
msgstr ""
"Densos aglomerados de asteróides detectados. Boas perspectivas para uma "
"operação mineira."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a massive, resource-rich asteroid field in this sector."
msgstr ""
"Mapeamos um campo de asteróides enorme e rico em recursos neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Heavy asteroid presence here. Prime territory for our mining lasers."
msgstr ""
"Presença pesada de asteróides aqui. Território privilegiado para nossos "
"lasers de mineração."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners show a dense field of unmined rocks in this sector."
msgstr "Os scanners mostram um denso campo de rochas não minadas neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Hostile pirate signatures detected. They are heavily entrenched in this "
"sector."
msgstr ""
"Assinaturas de piratas hostis detectadas. Eles estão fortemente enraizados "
"neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A major pirate syndicate controls this area. Approach with weapons hot."
msgstr ""
"Um grande sindicato pirata controla esta área. Aproxime-se com armas "
"quentes."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors are lighting up with raider transponders. It's a pirate stronghold."
msgstr ""
"Os sensores estão acendendo com transponders raider. É uma fortaleza pirata."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We spotted a large contingent of pirate scum operating in this sector."
msgstr "Vimos um grande contingente de piratas operando neste setor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive alien energy spikes detected. The Xsotan are swarming here."
msgstr ""
"Enormes picos de energia alienígena detectados. Os Xsotan estão fervilhando "
"aqui."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We barely avoided a massive Xsotan breeding cluster in this sector."
msgstr ""
"Por pouco não conseguimos evitar um enorme aglomerado de criação de Xsotan "
"neste sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is heavily infested by the Xsotan menace."
msgstr "Este sector está fortemente infestado pela ameaça Xsotan."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Alien bio-signatures confirmed. The Xsotan have claimed this space."
msgstr ""
"Assinaturas biológicas alienígenas confirmadas. Os Xsotan reivindicaram este"
" espaço."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We also picked up a repeating automated beacon on a forgotten frequency."
msgstr ""
"Também detectámos um sinal automático repetido numa frequência esquecida."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There's a strange navigational beacon here transmitting encrypted "
"coordinates."
msgstr ""
"Há um estranho farol de navegação aqui transmitindo coordenadas "
"criptografadas."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Also, a lone beacon is pulsing an 'Exodus' distress signal."
msgstr ""
"Além disso, um farol solitário está pulsando um sinal de socorro 'Êxodo'."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Oh, and I noted an ancient beacon broadcasting fragments of a mysterious "
"message."
msgstr ""
"Ah, e notei um antigo farol transmitindo fragmentos de uma mensagem "
"misteriosa."

# ========== data/scripts/player/background/simulation/simulation.lua
# ==========
#: data/scripts/player/background/simulation/simulation.lua:
msgid "Your captains continued working while you were away."
msgstr "Seus capitães continuaram trabalhando enquanto você estava fora."

# ========== data/scripts/player/background/simulation/simulationutility.lua
# ==========
#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "I'll have regular data for you as the mission progresses."
msgstr "Terei dados regulares para você à medida que a missão avança."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "You'll receive frequent updates as we learn more."
msgstr "Você receberá atualizações frequentes à medida que aprendermos mais."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Expect a continual flow of new information."
msgstr "Espere um fluxo contínuo de novas informações."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(d93)We have no deep scan ability and will have to visit every "
"sector.\\c()"
msgstr ""
"\\c(d93)Não temos capacidade de varredura profunda e teremos que visitar "
"todos os setores.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)Travel time will be extreme without more deep scan coverage.\\c()"
msgstr ""
"\\c(d93)O tempo de viagem será extremo sem uma cobertura de varredura mais "
"profunda.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(d93)We can't see where hidden mass sectors are without better "
"radar.\\c()"
msgstr ""
"\\c(d93)Não podemos ver onde estão os setores de massa ocultos sem um radar "
"melhor.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(dd5)With our weak sensors, we'll waste a lot of time jumping "
"blindly.\\c()"
msgstr ""
"\\c(dd5)Com nossos sensores fracos, perderemos muito tempo pulando às "
"cegas.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)We'd be a lot faster with more deep scan coverage.\\c()"
msgstr ""
"\\c(dd5)Seríamos muito mais rápidos com uma cobertura de varredura mais "
"profunda.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(dd5)Hidden mass sectors will be hard to find without better radar.\\c()"
msgstr ""
"\\c(dd5) Setores de massa ocultos serão difíceis de encontrar sem um radar "
"melhor.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)There's a refinery right here, so this will be fast and safe.\\c()"
msgstr "\\c(0d0)Há uma refinaria bem aqui, então isso será rápido e seguro.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(0d0)Refining will be no problem with a depot right in this sector.\\c()"
msgstr "\\c(0d0)Refinar não será problema com um depósito neste setor.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)I can autopilot right to the depot in this sector.\\c()"
msgstr ""
"\\c(0d0)Posso pilotar automaticamente direto para o depósito neste "
"setor.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)People are sure to appreciate our work here.\\c()"
msgstr "\\c(0d0)As pessoas certamente apreciarão nosso trabalho aqui.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)This will help a lot of people.\\c()"
msgstr "\\c(0d0)Isso ajudará muitas pessoas.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)Our generosity will help to build trust.\\c()"
msgstr "\\c(0d0)Nossa generosidade ajudará a construir confiança.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)This isn't my specialty, but I'll see what I can do.\\c()"
msgstr ""
"\\c(dd5)Essa não é minha especialidade, mas vou ver o que posso fazer.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)A merchant would do this better, but I can give it a go.\\c()"
msgstr "\\c(dd5)Um comerciante faria isso melhor, mas posso tentar.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)No merchants available, commander?\\c()"
msgstr "\\c(dd5)Nenhum comerciante disponível, comandante?\\c()"

