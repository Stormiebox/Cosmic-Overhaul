# ========== data/scripts/player/background/simulation/simulationutility.lua ==========
#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "I'll have regular data for you as the mission progresses."
msgstr "Tendré datos regulares para ti a medida que avance la misión."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "You'll receive frequent updates as we learn more."
msgstr "Recibirás actualizaciones frecuentes a medida que aprendamos más."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Expect a continual flow of new information."
msgstr "Espera un flujo continuo de información nueva."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)We have no deep scan ability and will have to visit every sector.\\c()"
msgstr "\\c(d93)No tenemos capacidad de escaneo profundo y tendremos que visitar cada sector.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)Travel time will be extreme without more deep scan coverage.\\c()"
msgstr "\\c(d93)El tiempo de viaje será extremo sin más cobertura de escaneo profundo.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)We can't see where hidden mass sectors are without better radar.\\c()"
msgstr "\\c(d93)No podemos ver dónde están los sectores de masa oculta sin un mejor radar.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)With our weak sensors, we'll waste a lot of time jumping blindly.\\c()"
msgstr "\\c(dd5)Con nuestros débiles sensores, perderemos mucho tiempo saltando a ciegas.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)We'd be a lot faster with more deep scan coverage.\\c()"
msgstr "\\c(dd5)Seríamos mucho más rápidos con más cobertura de escaneo profundo.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)Hidden mass sectors will be hard to find without better radar.\\c()"
msgstr "\\c(dd5)Los sectores de masa oculta serán difíciles de encontrar sin un mejor radar.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)There's a refinery right here, so this will be fast and safe.\\c()"
msgstr "\\c(0d0)Hay una refinería justo aquí, así que esto será rápido y seguro.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)Refining will be no problem with a depot right in this sector.\\c()"
msgstr "\\c(0d0)Refinar no será un problema con un depósito en este mismo sector.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)I can autopilot right to the depot in this sector.\\c()"
msgstr "\\c(0d0)Puedo usar el piloto automático directo al depósito en este sector.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)People are sure to appreciate our work here.\\c()"
msgstr "\\c(0d0)La gente seguro apreciará nuestro trabajo aquí.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)This will help a lot of people.\\c()"
msgstr "\\c(0d0)Esto ayudará a mucha gente.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)Our generosity will help to build trust.\\c()"
msgstr "\\c(0d0)Nuestra generosidad ayudará a generar confianza.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)This isn't my specialty, but I'll see what I can do.\\c()"
msgstr "\\c(dd5)Esta no es mi especialidad, pero veré qué puedo hacer.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)A merchant would do this better, but I can give it a go.\\c()"
msgstr "\\c(dd5)Un mercader lo haría mejor, pero puedo intentarlo.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)No merchants available, commander?\\c()"
msgstr "\\c(dd5)¿No hay mercaderes disponibles, comandante?\\c()"


