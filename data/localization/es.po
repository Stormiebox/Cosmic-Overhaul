#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners picked up a lone wormhole hidden in the void of this sector."
msgstr ""
"Los escáneres detectaron un solitario agujero de gusano escondido en el "
"vacío de este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a wormhole phenomenon active here. Destination unknown."
msgstr ""
"Aquí hay un fenómeno de agujero de gusano activo. Destino desconocido."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We intercepted a repeating broadcast from a lone research satellite."
msgstr ""
"Interceptamos una transmisión repetida desde un satélite de investigación "
"solitario."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive debris fields and wrecked hulls detected in this sector."
msgstr ""
"En este sector se detectaron enormes campos de escombros y cascos hundidos."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is littered with the husks of dead ships."
msgstr "Este sector está lleno de cascos de barcos muertos."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A massive stash of lost cargo containers is floating freely here."
msgstr ""
"Un enorme alijo de contenedores de carga perdidos flota libremente aquí."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We picked up encrypted comms. Looks like a black market hub is nearby."
msgstr ""
"Detectamos comunicaciones cifradas. Parece que hay un mercado negro cerca."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A shady syndicate operates a hidden Smuggler's Market in this sector."
msgstr ""
"Un sindicato turbio opera un mercado de contrabandistas oculto en este "
"sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a hive of scum and villainy tucked away in this area."
msgstr "Hay un hervidero de escoria y villanía escondido en esta área."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a massive, resource-rich asteroid field in this sector."
msgstr ""
"Mapeamos un campo de asteroides masivo y rico en recursos en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Heavy asteroid presence here. Prime territory for our mining lasers."
msgstr ""
"Fuerte presencia de asteroides aquí. Territorio privilegiado para nuestros "
"láseres de minería."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners show a dense field of unmined rocks in this sector."
msgstr ""
"Los escáneres muestran un denso campo de rocas no minadas en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We spotted a large contingent of pirate scum operating in this sector."
msgstr ""
"Detectamos un gran contingente de escoria pirata operando en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive alien energy spikes detected. The Xsotan are swarming here."
msgstr ""
"Detectados picos masivos de energía alienígena. Los xsotan pululan por aquí."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We barely avoided a massive Xsotan breeding cluster in this sector."
msgstr "Apenas evitamos un enorme grupo de cría de Xsotan en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is heavily infested by the Xsotan menace."
msgstr "Este sector está fuertemente infestado por la amenaza xsotan."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Alien bio-signatures confirmed. The Xsotan have claimed this space."
msgstr ""
"Se confirman biofirmas extraterrestres. Los Xsotan han reclamado este "
"espacio."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Also, a lone beacon is pulsing an 'Exodus' distress signal."
msgstr "Además, una baliza solitaria emite una señal de socorro 'Éxodo'."

# ========== data/scripts/player/background/simulation/simulation.lua
# ==========
#: data/scripts/player/background/simulation/simulation.lua:
msgid "Your captains continued working while you were away."
msgstr "Tus capitanes continuaron trabajando mientras no estabas."

# ========== data/scripts/player/background/simulation/simulationutility.lua
# ==========
#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "I'll have regular data for you as the mission progresses."
msgstr "Tendré datos regulares para ti a medida que avance la misión."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "You'll receive frequent updates as we learn more."
msgstr "Recibirás actualizaciones frecuentes a medida que aprendamos más."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Expect a continual flow of new information."
msgstr "Espera un flujo continuo de información nueva."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)Travel time will be extreme without more deep scan coverage.\\c()"
msgstr ""
"\\c(d93)El tiempo de viaje será extremo sin más cobertura de escaneo "
"profundo.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)We'd be a lot faster with more deep scan coverage.\\c()"
msgstr ""
"\\c(dd5)Seríamos mucho más rápidos con más cobertura de escaneo "
"profundo.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)There's a refinery right here, so this will be fast and safe.\\c()"
msgstr ""
"\\c(0d0)Hay una refinería justo aquí, así que esto será rápido y "
"seguro.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)I can autopilot right to the depot in this sector.\\c()"
msgstr ""
"\\c(0d0)Puedo usar el piloto automático directo al depósito en este "
"sector.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)People are sure to appreciate our work here.\\c()"
msgstr "\\c(0d0)La gente seguro apreciará nuestro trabajo aquí.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)This will help a lot of people.\\c()"
msgstr "\\c(0d0)Esto ayudará a mucha gente.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)Our generosity will help to build trust.\\c()"
msgstr "\\c(0d0)Nuestra generosidad ayudará a generar confianza.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)This isn't my specialty, but I'll see what I can do.\\c()"
msgstr "\\c(dd5)Esta no es mi especialidad, pero veré qué puedo hacer.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)A merchant would do this better, but I can give it a go.\\c()"
msgstr "\\c(dd5)Un mercader lo haría mejor, pero puedo intentarlo.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)No merchants available, commander?\\c()"
msgstr "\\c(dd5)¿No hay mercaderes disponibles, comandante?\\c()"

