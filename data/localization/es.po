# ==========
# ==========
# data/scripts/player/background/simulation/scoutcommandnotetable.lua
# ==========
#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors picked up a massive, dormant gate structure adrift in this sector."
msgstr ""
"Los sensores detectaron una enorme estructura de puerta inactiva a la deriva"
" en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We found a colossal ring gate here. It looks ancient and entirely dead."
msgstr ""
"Aquí encontramos una puerta circular colosal. Parece antiguo y completamente"
" muerto."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is an enormous, deactivated hyperspace gate floating silently in this "
"sector."
msgstr ""
"Hay una enorme puerta hiperespacial desactivada flotando silenciosamente en "
"este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We mapped a monolithic ancient gate construct. Its original builders are "
"long gone."
msgstr ""
"Mapeamos una construcción de puerta antigua monolítica. Sus constructores "
"originales desaparecieron hace mucho tiempo."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Asteroids in a perfect ring formation are emitting bizarre energy readings "
"here. We kept our distance."
msgstr ""
"Los asteroides en una formación de anillo perfecta emiten aquí extrañas "
"lecturas de energía. Mantuvimos nuestra distancia."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We detected a massive energy shield tethered to a cluster of glowing "
"asteroids."
msgstr ""
"Detectamos un enorme escudo de energía atado a un grupo de asteroides "
"brillantes."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is a highly suspicious, shielded rock formation in this sector. "
"Proceed with caution."
msgstr ""
"En este sector existe una formación rocosa protegida y muy sospechosa. "
"Proceda con precaución."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"An unnatural arrangement of asteroids is broadcasting a hostile energy "
"signature in this area."
msgstr ""
"Una disposición antinatural de asteroides emite una señal de energía hostil "
"en esta zona."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors picked up a group of zealots obsessing over a massive asteroid."
msgstr ""
"Los sensores detectaron a un grupo de fanáticos obsesionados con un "
"asteroide masivo."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A strange cult seems to have set up camp around a giant rock in this sector."
msgstr ""
"Un extraño culto parece haber acampado alrededor de una roca gigante en este"
" sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We intercepted some unhinged radio chatter. Cultists are congregating around"
" an asteroid here."
msgstr ""
"Interceptamos algunas conversaciones de radio desquiciadas. Aquí los "
"cultistas se están congregando alrededor de un asteroide."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There are fanatics out here worshipping an asteroid. Space madness is a "
"terrible thing."
msgstr ""
"Hay fanáticos aquí que adoran a un asteroide. La locura espacial es algo "
"terrible."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A localized spatial tear is present here. Looks like a stable wormhole."
msgstr ""
"Aquí hay un desgarro espacial localizado. Parece un agujero de gusano "
"estable."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners picked up a lone wormhole hidden in the void of this sector."
msgstr ""
"Los escáneres detectaron un solitario agujero de gusano escondido en el "
"vacío de este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a wormhole phenomenon active here. Destination unknown."
msgstr ""
"Aquí hay un fenómeno de agujero de gusano activo. Destino desconocido."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We almost stumbled straight into a spatial anomaly. A wormhole is open in "
"this sector."
msgstr ""
"Casi tropezamos directamente con una anomalía espacial. En este sector hay "
"un agujero de gusano abierto."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We intercepted a repeating broadcast from a lone research satellite."
msgstr ""
"Interceptamos una transmisión repetida desde un satélite de investigación "
"solitario."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"An automated science probe is transmitting strange data about asteroids "
"here."
msgstr ""
"Una sonda científica automatizada transmite aquí datos extraños sobre "
"asteroides."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A solitary satellite is pinging complex research telemetry in this sector."
msgstr ""
"Un satélite solitario está haciendo ping a una compleja telemetría de "
"investigación en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is an abandoned satellite registered to 'M.A.D. Science' looping its "
"logs here."
msgstr ""
"Hay un satélite abandonado registrado a nombre de 'M.A.D. La ciencia está "
"repitiendo sus registros aquí."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We stumbled upon a hidden resistance cell operating completely off the grid."
msgstr ""
"Nos topamos con una célula de resistencia oculta que operaba completamente "
"fuera de la red."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Against all odds, there's a scrappy survivor outpost tucked away in this "
"sector."
msgstr ""
"Contra todo pronóstico, hay un puesto avanzado de supervivientes escondido "
"en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A heavily concealed resistance faction is holding out against the Xsotan "
"here."
msgstr ""
"Una facción de resistencia fuertemente oculta se resiste aquí contra los "
"xsotan."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We found a pocket of survivors out here claiming to be part of a rebellion."
msgstr ""
"Encontramos un grupo de supervivientes aquí que afirman ser parte de una "
"rebelión."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"An artificial ring of numbered asteroids and strange stations is adrift "
"here."
msgstr ""
"Aquí se encuentra a la deriva un anillo artificial de asteroides numerados y"
" estaciones extrañas."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We found a complex arrangement of asteroids with strange numerical markings."
msgstr ""
"Encontramos una disposición compleja de asteroides con extrañas marcas "
"numéricas."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A dormant, circular array of asteroids and Xsotan tech is floating in this "
"sector."
msgstr ""
"En este sector flota un conjunto circular inactivo de asteroides y "
"tecnología Xsotan."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is a bizarre, ritualistic ring of marked asteroids generating faint "
"energy spikes."
msgstr ""
"Hay un anillo extraño y ritual de asteroides marcados que generan débiles "
"picos de energía."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors show a derelict ship with an intact core. We could restore it to "
"working order."
msgstr ""
"Los sensores muestran un barco abandonado con el núcleo intacto. Podríamos "
"restaurarlo para que funcione."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There's a heavily damaged but structurally sound ship abandoned in this "
"sector."
msgstr ""
"Hay un barco muy dañado pero estructuralmente sano abandonado en este "
"sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We located an intact derelict vessel here. With a solid repair crew, she'll "
"fly again."
msgstr ""
"Localizamos una embarcación abandonada intacta aquí. Con un equipo de "
"reparación sólido, volverá a volar."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"I spotted a salvageable ship out here. It is practically begging to be "
"claimed and repaired."
msgstr ""
"Vi un barco rescatable aquí. Prácticamente está pidiendo a gritos que lo "
"reclamen y lo reparen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive debris fields and wrecked hulls detected in this sector."
msgstr ""
"En este sector se detectaron enormes campos de escombros y cascos hundidos."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We mapped a graveyard of destroyed ships here. Prime salvaging territory."
msgstr ""
"Aquí mapeamos un cementerio de barcos destruidos. Primer territorio de "
"salvamento."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is littered with the husks of dead ships."
msgstr "Este sector está lleno de cascos de barcos muertos."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors show heavy wreckage concentrations in this area. Bring your salvage "
"lasers."
msgstr ""
"Los sensores muestran grandes concentraciones de restos en esta zona. Traiga"
" sus láseres de rescate."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A massive stash of lost cargo containers is floating freely here."
msgstr ""
"Un enorme alijo de contenedores de carga perdidos flota libremente aquí."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We detected a dense cluster of abandoned shipping containers in this sector."
msgstr ""
"Detectamos un denso grupo de contenedores marítimos abandonados en este "
"sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There is a veritable goldmine of unbranded cargo crates adrift out here."
msgstr ""
"Aquí hay una verdadera mina de oro de cajas de carga sin marca a la deriva."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors picked up a large, unsecured container cache drifting in the void."
msgstr ""
"Los sensores detectaron un gran contenedor inseguro flotando en el vacío."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We picked up encrypted comms. Looks like a black market hub is nearby."
msgstr ""
"Detectamos comunicaciones cifradas. Parece que hay un mercado negro cerca."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A shady syndicate operates a hidden Smuggler's Market in this sector."
msgstr ""
"Un sindicato turbio opera un mercado de contrabandistas oculto en este "
"sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors detected a heavily cloaked Smuggler's Hideout operating off the "
"books."
msgstr ""
"Los sensores detectaron un escondite de contrabandistas fuertemente "
"encubierto operando fuera de los libros."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a hive of scum and villainy tucked away in this area."
msgstr "Hay un hervidero de escoria y villanía escondido en esta área."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Dense asteroid clusters detected. Good prospects for a mining operation."
msgstr ""
"Detectados densos cúmulos de asteroides. Buenas perspectivas para una "
"operación minera."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a massive, resource-rich asteroid field in this sector."
msgstr ""
"Mapeamos un campo de asteroides masivo y rico en recursos en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Heavy asteroid presence here. Prime territory for our mining lasers."
msgstr ""
"Fuerte presencia de asteroides aquí. Territorio privilegiado para nuestros "
"láseres de minería."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners show a dense field of unmined rocks in this sector."
msgstr ""
"Los escáneres muestran un denso campo de rocas no minadas en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Hostile pirate signatures detected. They are heavily entrenched in this "
"sector."
msgstr ""
"Se detectaron firmas de piratas hostiles. Están muy arraigados en este "
"sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"A major pirate syndicate controls this area. Approach with weapons hot."
msgstr ""
"Un importante sindicato pirata controla esta zona. Acércate con armas "
"calientes."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Sensors are lighting up with raider transponders. It's a pirate stronghold."
msgstr ""
"Los sensores se están iluminando con transpondedores de asaltantes. Es una "
"fortaleza pirata."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We spotted a large contingent of pirate scum operating in this sector."
msgstr ""
"Detectamos un gran contingente de escoria pirata operando en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive alien energy spikes detected. The Xsotan are swarming here."
msgstr ""
"Detectados picos masivos de energía alienígena. Los xsotan pululan por aquí."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We barely avoided a massive Xsotan breeding cluster in this sector."
msgstr "Apenas evitamos un enorme grupo de cría de Xsotan en este sector."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is heavily infested by the Xsotan menace."
msgstr "Este sector está fuertemente infestado por la amenaza xsotan."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Alien bio-signatures confirmed. The Xsotan have claimed this space."
msgstr ""
"Se confirman biofirmas extraterrestres. Los Xsotan han reclamado este "
"espacio."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"We also picked up a repeating automated beacon on a forgotten frequency."
msgstr ""
"También detectamos una baliza automática que se repite en una frecuencia "
"olvidada."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"There's a strange navigational beacon here transmitting encrypted "
"coordinates."
msgstr ""
"Hay una extraña baliza de navegación aquí que transmite coordenadas "
"cifradas."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Also, a lone beacon is pulsing an 'Exodus' distress signal."
msgstr "Además, una baliza solitaria emite una señal de socorro 'Éxodo'."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid ""
"Oh, and I noted an ancient beacon broadcasting fragments of a mysterious "
"message."
msgstr ""
"Ah, y noté una antigua baliza que transmitía fragmentos de un mensaje "
"misterioso."

# ========== data/scripts/player/background/simulation/simulation.lua
# ==========
#: data/scripts/player/background/simulation/simulation.lua:
msgid "Your captains continued working while you were away."
msgstr "Tus capitanes continuaron trabajando mientras no estabas."

# ========== data/scripts/player/background/simulation/simulationutility.lua
# ==========
#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "I'll have regular data for you as the mission progresses."
msgstr "Tendré datos regulares para ti a medida que avance la misión."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "You'll receive frequent updates as we learn more."
msgstr "Recibirás actualizaciones frecuentes a medida que aprendamos más."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Expect a continual flow of new information."
msgstr "Espera un flujo continuo de información nueva."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(d93)We have no deep scan ability and will have to visit every "
"sector.\\c()"
msgstr ""
"\\c(d93)No tenemos capacidad de escaneo profundo y tendremos que visitar "
"cada sector.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)Travel time will be extreme without more deep scan coverage.\\c()"
msgstr ""
"\\c(d93)El tiempo de viaje será extremo sin más cobertura de escaneo "
"profundo.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(d93)We can't see where hidden mass sectors are without better "
"radar.\\c()"
msgstr ""
"\\c(d93)No podemos ver dónde están los sectores de masa oculta sin un mejor "
"radar.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(dd5)With our weak sensors, we'll waste a lot of time jumping "
"blindly.\\c()"
msgstr ""
"\\c(dd5)Con nuestros débiles sensores, perderemos mucho tiempo saltando a "
"ciegas.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)We'd be a lot faster with more deep scan coverage.\\c()"
msgstr ""
"\\c(dd5)Seríamos mucho más rápidos con más cobertura de escaneo "
"profundo.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(dd5)Hidden mass sectors will be hard to find without better radar.\\c()"
msgstr ""
"\\c(dd5)Los sectores de masa oculta serán difíciles de encontrar sin un "
"mejor radar.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)There's a refinery right here, so this will be fast and safe.\\c()"
msgstr ""
"\\c(0d0)Hay una refinería justo aquí, así que esto será rápido y "
"seguro.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid ""
"\\c(0d0)Refining will be no problem with a depot right in this sector.\\c()"
msgstr ""
"\\c(0d0)Refinar no será un problema con un depósito en este mismo "
"sector.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)I can autopilot right to the depot in this sector.\\c()"
msgstr ""
"\\c(0d0)Puedo usar el piloto automático directo al depósito en este "
"sector.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)People are sure to appreciate our work here.\\c()"
msgstr "\\c(0d0)La gente seguro apreciará nuestro trabajo aquí.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)This will help a lot of people.\\c()"
msgstr "\\c(0d0)Esto ayudará a mucha gente.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)Our generosity will help to build trust.\\c()"
msgstr "\\c(0d0)Nuestra generosidad ayudará a generar confianza.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)This isn't my specialty, but I'll see what I can do.\\c()"
msgstr "\\c(dd5)Esta no es mi especialidad, pero veré qué puedo hacer.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)A merchant would do this better, but I can give it a go.\\c()"
msgstr "\\c(dd5)Un mercader lo haría mejor, pero puedo intentarlo.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)No merchants available, commander?\\c()"
msgstr "\\c(dd5)¿No hay mercaderes disponibles, comandante?\\c()"

