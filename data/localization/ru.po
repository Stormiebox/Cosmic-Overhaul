msgstr "Вносить прибыль напрямую, как только она станет доступна"

#: data/scripts/player/background/simulation/tradecommand.lua:
msgid "Immediate delivery"
msgstr "Немедленная доставка"

#: data/scripts/player/background/simulation/tradecommand.lua:
