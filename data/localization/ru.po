# ========== data/scripts/entity/TrashMan.lua ==========
#: data/scripts/entity/TrashMan.lua:
msgid "Trash Man"
msgstr "Мусорщик"

#: data/scripts/entity/TrashMan.lua:
msgid "Systems to trash"
msgstr "Системы в мусор"

#: data/scripts/entity/TrashMan.lua:
msgid "Turrets to trash"
msgstr "Турели в мусор"

#: data/scripts/entity/TrashMan.lua:
msgid "Select which types of inventory items to mark as trash. These items will not be destroyed or immediately sold. Instead, the next time you visit the appropriate merchant they can be sold with the merchant's 'Sell Trash' button.\nItems that are marked as favorites will not get marked for trash!"
msgstr "Выберите, какие типы предметов инвентаря пометить как мусор. Эти предметы не будут уничтожены или немедленно проданы. Вместо этого при следующем посещении соответствующего торговца их можно будет продать с помощью кнопки «Продать мусор».\nПредметы, отмеченные как избранные, не будут помечены как мусор!"

#: data/scripts/entity/TrashMan.lua:
msgid "Mark"
msgstr "Отметить"

#: data/scripts/entity/TrashMan.lua:
msgid "Unmark"
msgstr "Снять отметку"

#: data/scripts/entity/TrashMan.lua:
msgid "Preview"
msgstr "Предварительный просмотр"

#: data/scripts/entity/TrashMan.lua:
msgid "Preview: not run yet"
msgstr "Предварительный просмотр: еще не запущен"

#: data/scripts/entity/TrashMan.lua:
msgid "Tech level filter (optional)"
msgstr "Фильтр тех. уровня (необязательно)"

#: data/scripts/entity/TrashMan.lua:
msgid "Min: 1"
msgstr "Мин: 1"

#: data/scripts/entity/TrashMan.lua:
msgid "Max: 52"
msgstr "Макс: 52"


