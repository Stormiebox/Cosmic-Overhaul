# ========== data/scripts/player/background/simulation/scoutcommandnotetable.lua ==========
#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors picked up a massive, dormant gate structure adrift in this sector."
msgstr "Сенсоры засекли массивную спящую структуру врат, дрейфующую в этом секторе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We found a colossal ring gate here. It looks ancient and entirely dead."
msgstr "Здесь мы нашли колоссальные кольцевые врата. Они выглядят древними и совершенно безжизненными."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is an enormous, deactivated hyperspace gate floating silently in this sector."
msgstr "В этом секторе безмолвно плывут огромные деактивированные гиперпространственные врата."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a monolithic ancient gate construct. Its original builders are long gone."
msgstr "Мы нанесли на карту монолитную конструкцию древних врат. Их первоначальных строителей давно нет."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Asteroids in a perfect ring formation are emitting bizarre energy readings here. We kept our distance."
msgstr "Астероиды в идеальном кольцевом построении излучают здесь странные энергетические сигналы. Мы держались на расстоянии."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We detected a massive energy shield tethered to a cluster of glowing asteroids."
msgstr "Мы обнаружили массивный энергетический щит, привязанный к скоплению светящихся астероидов."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a highly suspicious, shielded rock formation in this sector. Proceed with caution."
msgstr "В этом секторе есть очень подозрительное скальное образование с щитом. Действуйте с осторожностью."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "An unnatural arrangement of asteroids is broadcasting a hostile energy signature in this area."
msgstr "Неестественное расположение астероидов передает враждебную энергетическую сигнатуру в этом районе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors picked up a group of zealots obsessing over a massive asteroid."
msgstr "Сенсоры засекли группу фанатиков, одержимых массивным астероидом."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A strange cult seems to have set up camp around a giant rock in this sector."
msgstr "Похоже, странный культ разбил лагерь вокруг гигантской скалы в этом секторе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We intercepted some unhinged radio chatter. Cultists are congregating around an asteroid here."
msgstr "Мы перехватили какой-то безумный радиоперехват. Культисты собираются здесь вокруг астероида."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There are fanatics out here worshipping an asteroid. Space madness is a terrible thing."
msgstr "Здесь есть фанатики, поклоняющиеся астероиду. Космическое безумие — ужасная вещь."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A localized spatial tear is present here. Looks like a stable wormhole."
msgstr "Здесь присутствует локальный пространственный разрыв. Выглядит как стабильная червоточина."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners picked up a lone wormhole hidden in the void of this sector."
msgstr "Сканнеры засекли одинокую червоточину, скрытую в пустоте этого сектора."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a wormhole phenomenon active here. Destination unknown."
msgstr "Здесь активно явление червоточины. Пункт назначения неизвестен."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We almost stumbled straight into a spatial anomaly. A wormhole is open in this sector."
msgstr "Мы чуть не наткнулись прямо на пространственную аномалию. В этом секторе открыта червоточина."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We intercepted a repeating broadcast from a lone research satellite."
msgstr "Мы перехватили повторяющуюся трансляцию с одинокого исследовательского спутника."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "An automated science probe is transmitting strange data about asteroids here."
msgstr "Автоматический научный зонд передает отсюда странные данные об астероидах."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A solitary satellite is pinging complex research telemetry in this sector."
msgstr "Одинокий спутник передает сложную исследовательскую телеметрию в этом секторе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is an abandoned satellite registered to 'M.A.D. Science' looping its logs here."
msgstr "Здесь есть заброшенный спутник, зарегистрированный на 'Б.Е.З.У.М.Н.У.Ю Науку', который зацикленно передает свои журналы."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We stumbled upon a hidden resistance cell operating completely off the grid."
msgstr "Мы наткнулись на скрытую ячейку сопротивления, работающую полностью вне сети."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Against all odds, there's a scrappy survivor outpost tucked away in this sector."
msgstr "Вопреки всему, в этом секторе спрятан потрепанный аванпост выживших."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A heavily concealed resistance faction is holding out against the Xsotan here."
msgstr "Тщательно скрытая фракция сопротивления держится здесь против ксотанов."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We found a pocket of survivors out here claiming to be part of a rebellion."
msgstr "Мы нашли здесь горстку выживших, утверждающих, что они часть восстания."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "An artificial ring of numbered asteroids and strange stations is adrift here."
msgstr "Искусственное кольцо из пронумерованных астероидов и странных станций дрейфует здесь."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We found a complex arrangement of asteroids with strange numerical markings."
msgstr "Мы нашли сложное расположение астероидов со странными числовыми пометками."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A dormant, circular array of asteroids and Xsotan tech is floating in this sector."
msgstr "Спящий круговой массив астероидов и технологий ксотанов плавает в этом секторе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a bizarre, ritualistic ring of marked asteroids generating faint energy spikes."
msgstr "Существует причудливое, ритуальное кольцо отмеченных астероидов, генерирующее слабые всплески энергии."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors show a derelict ship with an intact core. We could restore it to working order."
msgstr "Сенсоры показывают покинутый корабль с неповрежденным ядром. Мы могли бы восстановить его работоспособность."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There's a heavily damaged but structurally sound ship abandoned in this sector."
msgstr "В этом секторе брошен сильно поврежденный, но структурно целый корабль."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We located an intact derelict vessel here. With a solid repair crew, she'll fly again."
msgstr "Мы обнаружили здесь неповрежденное брошенное судно. С хорошей ремонтной бригадой оно снова полетит."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "I spotted a salvageable ship out here. It is practically begging to be claimed and repaired."
msgstr "Я заметил здесь корабль, пригодный для спасения. Он практически умоляет, чтобы его забрали и отремонтировали."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive debris fields and wrecked hulls detected in this sector."
msgstr "В этом секторе обнаружены массивные поля обломков и разбитые корпуса."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a graveyard of destroyed ships here. Prime salvaging territory."
msgstr "Мы нанесли на карту кладбище уничтоженных кораблей здесь. Идеальная территория для утилизации."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is littered with the husks of dead ships."
msgstr "Этот сектор усеян остовами мертвых кораблей."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors show heavy wreckage concentrations in this area. Bring your salvage lasers."
msgstr "Сенсоры показывают большие скопления обломков в этом районе. Захватите свои утилизационные лазеры."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A massive stash of lost cargo containers is floating freely here."
msgstr "Здесь свободно плавает огромный тайник потерянных грузовых контейнеров."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We detected a dense cluster of abandoned shipping containers in this sector."
msgstr "В этом секторе мы обнаружили плотное скопление брошенных грузовых контейнеров."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a veritable goldmine of unbranded cargo crates adrift out here."
msgstr "Здесь дрейфует настоящая золотая жила грузовых ящиков без опознавательных знаков."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors picked up a large, unsecured container cache drifting in the void."
msgstr "Сенсоры засекли большой тайник с незакрепленными контейнерами, дрейфующий в пустоте."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We picked up encrypted comms. Looks like a black market hub is nearby."
msgstr "Мы перехватили зашифрованные сообщения. Похоже, рядом центр черного рынка."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A shady syndicate operates a hidden Smuggler's Market in this sector."
msgstr "Теневой синдикат управляет скрытым рынком контрабандистов в этом секторе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors detected a heavily cloaked Smuggler's Hideout operating off the books."
msgstr "Сенсоры обнаружили тщательно замаскированное убежище контрабандистов, работающее нелегально."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a hive of scum and villainy tucked away in this area."
msgstr "В этом районе спрятано логово отбросов общества и злодеев."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Dense asteroid clusters detected. Good prospects for a mining operation."
msgstr "Обнаружены плотные скопления астероидов. Хорошие перспективы для горнодобывающей операции."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a massive, resource-rich asteroid field in this sector."
msgstr "Мы нанесли на карту массивное, богатое ресурсами астероидное поле в этом секторе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Heavy asteroid presence here. Prime territory for our mining lasers."
msgstr "Здесь много астероидов. Идеальная территория для наших шахтерских лазеров."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners show a dense field of unmined rocks in this sector."
msgstr "Сканнеры показывают плотное поле нетронутых камней в этом секторе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Hostile pirate signatures detected. They are heavily entrenched in this sector."
msgstr "Обнаружены враждебные пиратские сигнатуры. Они прочно обосновались в этом секторе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A major pirate syndicate controls this area. Approach with weapons hot."
msgstr "Крупный пиратский синдикат контролирует эту зону. Приближаться с готовностью открыть огонь."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors are lighting up with raider transponders. It's a pirate stronghold."
msgstr "Сенсоры пестрят транспондерами рейдеров. Это пиратская твердыня."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We spotted a large contingent of pirate scum operating in this sector."
msgstr "Мы заметили крупный контингент пиратских отбросов, действующих в этом секторе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive alien energy spikes detected. The Xsotan are swarming here."
msgstr "Обнаружены массивные всплески инопланетной энергии. Здесь роятся ксотаны."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We barely avoided a massive Xsotan breeding cluster in this sector."
msgstr "Мы чудом избежали массивного рассадника ксотанов в этом секторе."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is heavily infested by the Xsotan menace."
msgstr "Этот сектор сильно заражен ксотанской угрозой."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Alien bio-signatures confirmed. The Xsotan have claimed this space."
msgstr "Инопланетные биосигнатуры подтверждены. Ксотаны заявили права на это пространство."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We also picked up a repeating automated beacon on a forgotten frequency."
msgstr "Мы также засекли повторяющийся автоматический маяк на забытой частоте."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There's a strange navigational beacon here transmitting encrypted coordinates."
msgstr "Здесь есть странный навигационный маяк, передающий зашифрованные координаты."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Also, a lone beacon is pulsing an 'Exodus' distress signal."
msgstr "Кроме того, одинокий маяк передает сигнал бедствия 'Исход'."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Oh, and I noted an ancient beacon broadcasting fragments of a mysterious message."
msgstr "О, и я заметил древний маяк, транслирующий фрагменты загадочного сообщения."


# ========== data/scripts/player/background/simulation/simulation.lua ==========
#: data/scripts/player/background/simulation/simulation.lua:
msgid "Your captains continued working while you were away."
msgstr "Ваши капитаны продолжали работать, пока вас не было."


# ========== data/scripts/player/background/simulation/simulationutility.lua ==========
#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "I'll have regular data for you as the mission progresses."
msgstr "По мере выполнения миссии я буду регулярно предоставлять вам данные."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "You'll receive frequent updates as we learn more."
msgstr "Вы будете часто получать обновления по мере того, как мы узнаем больше."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "Expect a continual flow of new information."
msgstr "Ожидайте непрерывный поток новой информации."

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)We have no deep scan ability and will have to visit every sector.\\c()"
msgstr "\\c(d93)У нас нет функции глубокого сканирования, и нам придется посетить каждый сектор.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)Travel time will be extreme without more deep scan coverage.\\c()"
msgstr "\\c(d93)Время в пути будет огромным без большего радиуса глубокого сканирования.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(d93)We can't see where hidden mass sectors are without better radar.\\c()"
msgstr "\\c(d93)Без лучшего радара мы не сможем увидеть, где находятся сектора со скрытой массой.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)With our weak sensors, we'll waste a lot of time jumping blindly.\\c()"
msgstr "\\c(dd5)С нашими слабыми сенсорами мы потратим много времени, прыгая вслепую.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)We'd be a lot faster with more deep scan coverage.\\c()"
msgstr "\\c(dd5)Мы были бы намного быстрее с большим радиусом глубокого сканирования.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)Hidden mass sectors will be hard to find without better radar.\\c()"
msgstr "\\c(dd5)Сектора со скрытой массой будет трудно найти без лучшего радара.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)There's a refinery right here, so this will be fast and safe.\\c()"
msgstr "\\c(0d0)Здесь есть обогатительная фабрика, так что это будет быстро и безопасно.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)Refining will be no problem with a depot right in this sector.\\c()"
msgstr "\\c(0d0)Переработка не будет проблемой с хранилищем прямо в этом секторе.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)I can autopilot right to the depot in this sector.\\c()"
msgstr "\\c(0d0)Я могу включить автопилот прямо до хранилища в этом секторе.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)People are sure to appreciate our work here.\\c()"
msgstr "\\c(0d0)Люди обязательно оценят нашу работу здесь.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)This will help a lot of people.\\c()"
msgstr "\\c(0d0)Это поможет многим людям.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(0d0)Our generosity will help to build trust.\\c()"
msgstr "\\c(0d0)Наша щедрость поможет завоевать доверие.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)This isn't my specialty, but I'll see what I can do.\\c()"
msgstr "\\c(dd5)Это не моя специализация, но я посмотрю, что смогу сделать.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)A merchant would do this better, but I can give it a go.\\c()"
msgstr "\\c(dd5)Купец справился бы с этим лучше, но я могу попробовать.\\c()"

#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "\\c(dd5)No merchants available, commander?\\c()"
msgstr "\\c(dd5)Нет доступных купцов, командир?\\c()"


