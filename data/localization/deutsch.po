# ========== data/scripts/player/background/simulation/scoutcommandnotetable.lua ==========
#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors picked up a massive, dormant gate structure adrift in this sector."
msgstr "Sensoren haben eine massive, inaktive Torstruktur erfasst, die in diesem Sektor treibt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We found a colossal ring gate here. It looks ancient and entirely dead."
msgstr "Wir haben hier ein kolossales Ringtor gefunden. Es sieht uralt und völlig tot aus."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is an enormous, deactivated hyperspace gate floating silently in this sector."
msgstr "In diesem Sektor treibt lautlos ein riesiges, deaktiviertes Hyperraumtor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a monolithic ancient gate construct. Its original builders are long gone."
msgstr "Wir haben ein monolithisches antikes Tor-Konstrukt kartiert. Seine ursprünglichen Erbauer sind längst verschwunden."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Asteroids in a perfect ring formation are emitting bizarre energy readings here. We kept our distance."
msgstr "Asteroiden in einer perfekten Ringformation strahlen hier bizarre Energiewerte ab. Wir haben Abstand gehalten."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We detected a massive energy shield tethered to a cluster of glowing asteroids."
msgstr "Wir haben einen massiven Energieschild entdeckt, der an einen Haufen leuchtender Asteroiden gebunden ist."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a highly suspicious, shielded rock formation in this sector. Proceed with caution."
msgstr "In diesem Sektor befindet sich eine höchst verdächtige, abgeschirmte Felsformation. Vorsicht walten lassen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "An unnatural arrangement of asteroids is broadcasting a hostile energy signature in this area."
msgstr "Eine unnatürliche Anordnung von Asteroiden sendet in diesem Bereich eine feindliche Energiesignatur aus."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors picked up a group of zealots obsessing over a massive asteroid."
msgstr "Sensoren haben eine Gruppe von Eiferern erfasst, die von einem massiven Asteroiden besessen sind."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A strange cult seems to have set up camp around a giant rock in this sector."
msgstr "Ein seltsamer Kult scheint in diesem Sektor um einen riesigen Felsen herum ein Lager aufgeschlagen zu haben."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We intercepted some unhinged radio chatter. Cultists are congregating around an asteroid here."
msgstr "Wir haben verwirrten Funkverkehr abgefangen. Kultisten versammeln sich hier um einen Asteroiden."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There are fanatics out here worshipping an asteroid. Space madness is a terrible thing."
msgstr "Hier draußen verehren Fanatiker einen Asteroiden. Weltraumwahnsinn ist eine schreckliche Sache."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A localized spatial tear is present here. Looks like a stable wormhole."
msgstr "Hier ist ein lokalisierter Riss im Raum. Sieht aus wie ein stabiles Wurmloch."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners picked up a lone wormhole hidden in the void of this sector."
msgstr "Scanner haben ein einsames Wurmloch erfasst, das in der Leere dieses Sektors verborgen ist."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a wormhole phenomenon active here. Destination unknown."
msgstr "Hier ist ein Wurmloch-Phänomen aktiv. Ziel unbekannt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We almost stumbled straight into a spatial anomaly. A wormhole is open in this sector."
msgstr "Wir sind fast direkt in eine Raumanomalie gestolpert. Ein Wurmloch ist in diesem Sektor offen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We intercepted a repeating broadcast from a lone research satellite."
msgstr "Wir haben eine sich wiederholende Übertragung von einem einsamen Forschungssatelliten abgefangen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "An automated science probe is transmitting strange data about asteroids here."
msgstr "Eine automatisierte Wissenschaftssonde überträgt hier seltsame Daten über Asteroiden."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A solitary satellite is pinging complex research telemetry in this sector."
msgstr "Ein einzelner Satellit sendet in diesem Sektor komplexe Forschungstelemetrie."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is an abandoned satellite registered to 'M.A.D. Science' looping its logs here."
msgstr "Hier schleift ein verlassener Satellit, der auf 'M.A.D. Science' registriert ist, seine Protokolle."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We stumbled upon a hidden resistance cell operating completely off the grid."
msgstr "Wir sind auf eine versteckte Widerstandszelle gestoßen, die völlig autark operiert."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Against all odds, there's a scrappy survivor outpost tucked away in this sector."
msgstr "Entgegen allen Erwartungen gibt es in diesem Sektor einen hartnäckigen Überlebensaußenposten."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A heavily concealed resistance faction is holding out against the Xsotan here."
msgstr "Eine stark getarnte Widerstandsfraktion hält hier gegen die Xsotan stand."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We found a pocket of survivors out here claiming to be part of a rebellion."
msgstr "Wir haben hier draußen eine Gruppe von Überlebenden gefunden, die behaupten, Teil einer Rebellion zu sein."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "An artificial ring of numbered asteroids and strange stations is adrift here."
msgstr "Ein künstlicher Ring aus nummerierten Asteroiden und seltsamen Stationen treibt hier."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We found a complex arrangement of asteroids with strange numerical markings."
msgstr "Wir haben eine komplexe Anordnung von Asteroiden mit seltsamen numerischen Markierungen gefunden."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A dormant, circular array of asteroids and Xsotan tech is floating in this sector."
msgstr "Ein ruhendes, kreisförmiges Array von Asteroiden und Xsotan-Technologie treibt in diesem Sektor."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a bizarre, ritualistic ring of marked asteroids generating faint energy spikes."
msgstr "Es gibt einen bizarren, rituellen Ring aus markierten Asteroiden, der schwache Energiespitzen erzeugt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors show a derelict ship with an intact core. We could restore it to working order."
msgstr "Sensoren zeigen ein verlassenes Schiff mit intaktem Kern. Wir könnten es wieder fahrbereit machen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There's a heavily damaged but structurally sound ship abandoned in this sector."
msgstr "In diesem Sektor gibt es ein stark beschädigtes, aber strukturell intaktes Schiff."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We located an intact derelict vessel here. With a solid repair crew, she'll fly again."
msgstr "Wir haben hier ein intaktes, verlassenes Schiff gefunden. Mit einer guten Reparaturcrew wird es wieder fliegen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "I spotted a salvageable ship out here. It is practically begging to be claimed and repaired."
msgstr "Ich habe hier draußen ein bergbares Schiff entdeckt. Es bettelt praktisch darum, beansprucht und repariert zu werden."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive debris fields and wrecked hulls detected in this sector."
msgstr "In diesem Sektor wurden massive Trümmerfelder und zerstörte Schiffsrümpfe entdeckt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a graveyard of destroyed ships here. Prime salvaging territory."
msgstr "Wir haben hier einen Friedhof zerstörter Schiffe kartiert. Bestes Gebiet für Abwrackarbeiten."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is littered with the husks of dead ships."
msgstr "Dieser Sektor ist übersät mit den Hüllen toter Schiffe."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors show heavy wreckage concentrations in this area. Bring your salvage lasers."
msgstr "Sensoren zeigen starke Wrackkonzentrationen in diesem Bereich. Bringen Sie Ihre Abwracklaser mit."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A massive stash of lost cargo containers is floating freely here."
msgstr "Ein riesiges Versteck mit verlorenen Frachtcontainern treibt hier frei."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We detected a dense cluster of abandoned shipping containers in this sector."
msgstr "Wir haben in diesem Sektor eine dichte Ansammlung verlassener Frachtcontainer entdeckt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a veritable goldmine of unbranded cargo crates adrift out here."
msgstr "Hier draußen treibt eine wahre Goldmine aus nicht markierten Frachtkisten."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors picked up a large, unsecured container cache drifting in the void."
msgstr "Sensoren haben ein großes, ungesichertes Container-Versteck erfasst, das in der Leere treibt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We picked up encrypted comms. Looks like a black market hub is nearby."
msgstr "Wir haben verschlüsselte Kommunikation empfangen. Sieht so aus, als wäre ein Schwarzmarktknoten in der Nähe."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A shady syndicate operates a hidden Smuggler's Market in this sector."
msgstr "Ein zwielichtiges Syndikat betreibt in diesem Sektor einen versteckten Schmugglermarkt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors detected a heavily cloaked Smuggler's Hideout operating off the books."
msgstr "Sensoren haben ein stark getarntes Schmugglerversteck entdeckt, das inoffiziell operiert."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There is a hive of scum and villainy tucked away in this area."
msgstr "In dieser Gegend ist ein Hort von Abschaum und Schurkerei versteckt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Dense asteroid clusters detected. Good prospects for a mining operation."
msgstr "Dichte Asteroiden-Cluster entdeckt. Gute Aussichten für einen Bergbaubetrieb."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We mapped a massive, resource-rich asteroid field in this sector."
msgstr "Wir haben in diesem Sektor ein riesiges, ressourcenreiches Asteroidenfeld kartiert."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Heavy asteroid presence here. Prime territory for our mining lasers."
msgstr "Starkes Asteroidenaufkommen hier. Bestes Gebiet für unsere Bergbaulaser."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Scanners show a dense field of unmined rocks in this sector."
msgstr "Scanner zeigen in diesem Sektor ein dichtes Feld an noch nicht abgebauten Felsen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Hostile pirate signatures detected. They are heavily entrenched in this sector."
msgstr "Feindliche Piratensignaturen entdeckt. Sie haben sich in diesem Sektor stark verschanzt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "A major pirate syndicate controls this area. Approach with weapons hot."
msgstr "Ein großes Piratensyndikat kontrolliert dieses Gebiet. Nähern Sie sich mit feuerbereiten Waffen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Sensors are lighting up with raider transponders. It's a pirate stronghold."
msgstr "Die Sensoren leuchten mit Räuber-Transpondern auf. Es ist eine Piratenhochburg."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We spotted a large contingent of pirate scum operating in this sector."
msgstr "Wir haben ein großes Aufgebot an Piratenabschaum in diesem Sektor entdeckt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Massive alien energy spikes detected. The Xsotan are swarming here."
msgstr "Massive außerirdische Energiespitzen entdeckt. Die Xsotan schwärmen hier."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We barely avoided a massive Xsotan breeding cluster in this sector."
msgstr "Wir konnten einem massiven Xsotan-Brutcluster in diesem Sektor nur knapp ausweichen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "This sector is heavily infested by the Xsotan menace."
msgstr "Dieser Sektor ist stark von der Xsotan-Bedrohung befallen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Alien bio-signatures confirmed. The Xsotan have claimed this space."
msgstr "Außerirdische Bio-Signaturen bestätigt. Die Xsotan haben diesen Raum beansprucht."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "We also picked up a repeating automated beacon on a forgotten frequency."
msgstr "Wir haben auch ein sich wiederholendes automatisiertes Signal auf einer vergessenen Frequenz empfangen."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "There's a strange navigational beacon here transmitting encrypted coordinates."
msgstr "Hier gibt es ein seltsames Navigationssignal, das verschlüsselte Koordinaten überträgt."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Also, a lone beacon is pulsing an 'Exodus' distress signal."
msgstr "Außerdem pulsiert ein einsames Signal mit einem 'Exodus'-Notsignal."

#: data/scripts/player/background/simulation/scoutcommandnotetable.lua:
msgid "Oh, and I noted an ancient beacon broadcasting fragments of a mysterious message."
msgstr "Oh, und ich habe ein altes Signal bemerkt, das Fragmente einer mysteriösen Nachricht sendet."


# ========== data/scripts/player/background/simulation/simulation.lua ==========
#: data/scripts/player/background/simulation/simulation.lua:
msgid "Your captains continued working while you were away."
msgstr "Ihre Kapitäne haben weitergearbeitet, während Sie weg waren."


# ========== data/scripts/player/background/simulation/simulationutility.lua ==========
#: data/scripts/player/background/simulation/simulationutility.lua:
msgid "I'll have regular data for you as the mission progresses."
