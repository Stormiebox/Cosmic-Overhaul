#: data/scripts/entity/merchants/scrapyard.lua
msgid ""
"Wreckages in this sector are the property of %s. Please buy a salvaging "
"license."
msgstr ""
"Wrackteile in diesem Sektor sind Eigentum von%s. Bitte kaufen Sie eine "
"Bergungslizenz."

#: data/scripts/entity/merchants/smugglersmarket.lua
msgid "YOU"
msgstr "DU"

#: data/scripts/entity/merchants/smugglersmarket.lua
msgid "You bring 'em, we crack 'em. Secured Containers only."
msgstr "Du bringst sie, wir knacken sie. Nur gesicherte Container."

#: data/scripts/entity/merchants/smugglersmarket.lua
msgid "You can't sell ${displayPlural} here."
msgstr "Sie können hier nicht${displayPlural}verkaufen."

#: data/scripts/entity/merchants/scrapyard.lua
msgid "You don't have a valid license."
msgstr "Sie haben keine gültige Lizenz."

